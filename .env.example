# lib-service-discovery — environment variables
#
# Canonical, backend-agnostic SD_* names. Legacy names are still accepted as a
# fallback (SD_* takes precedence when both are set). Copy to .env and adjust.
# All values below are examples/defaults and are commented out — the library
# works with everything unset (discovery disabled, Resolve returns the fallback).

# Enable Consul-backed discovery. "true" to enable; anything else = disabled.
# Legacy fallback: SERVICE_DISCOVERY_ENABLED
#SD_ENABLED=true

# Discovery server address (host:port). Default: localhost:8500
# Legacy fallback: CONSUL_ADDR
#SD_ADDRESS=localhost:8500

# Address this instance advertises for the external / ingress view. Plain
# hostname ("fees.example.net") or full URL ("https://fees.example.net").
# Preferred name. Aliases (back-compat, SD_EXTERNAL_* wins): SD_ADVERTISE_ADDRESS,
# SERVICE_ADVERTISE_ADDR. At least one of SD_EXTERNAL_ADDRESS / SD_INTERNAL_ADDRESS
# is required when SD_ENABLED=true.
#SD_EXTERNAL_ADDRESS=svc-a
# Legacy alias for SD_EXTERNAL_ADDRESS (kept for back-compat):
#SD_ADVERTISE_ADDRESS=svc-a

# External port override. 0 (or unset) = use the port passed to Register.
# Preferred name. Aliases (back-compat): SD_ADVERTISE_PORT, SERVICE_ADVERTISE_PORT.
#SD_EXTERNAL_PORT=8081
# Legacy alias for SD_EXTERNAL_PORT (kept for back-compat):
#SD_ADVERTISE_PORT=8081

# In-cluster (Kubernetes service DNS) hostname or full URL for the internal
# endpoint. Empty = only the external endpoint is advertised. No legacy fallback.
#
# INTERNAL-ONLY DEPLOYMENT: to register a service reachable only inside the
# cluster, set SD_INTERNAL_ADDRESS (and optionally SD_INTERNAL_PORT) and OMIT
# SD_EXTERNAL_ADDRESS / SD_ADVERTISE_ADDRESS entirely. The instance then has no
# external endpoint: ResolveEndpoint(..., External) returns
# ErrEndpointViewUnavailable, while the internal view and legacy Resolve return
# the internal address.
#SD_INTERNAL_ADDRESS=svc-a.ns.svc.cluster.local

# Internal port override. 0 (or unset) = use the port passed to Register.
# No legacy fallback.
#SD_INTERNAL_PORT=8081

# URL scheme for the internal endpoint. Unset = Register defaults it to "http".
# No legacy fallback.
#SD_INTERNAL_SCHEME=http

# Default view for view-aware resolvers and ResolvePreferredEndpoint:
# internal or external. Default: external. No legacy fallback.
#SD_PREFER_VIEW=external

# Workload scope for tag-based isolation. Legacy fallback: WORKLOAD_ID
#SD_WORKLOAD=tenant-a

# Use HTTPS to the discovery server. "true" to enable. Default: false
#SD_TLS=true

# Skip discovery server certificate verification (dev / self-signed).
# "true" to enable. Default: false
#SD_TLS_SKIP_VERIFY=false

# ACL token sent to the discovery server.
#SD_TOKEN=

# ── Resilience / availability tuning (single-node BYOC Consul) ────────────────
# These harden the library against an unavailable discovery server. They are
# transport-level connection timeouts (Go duration syntax: "5s", "1m"), NOT a
# whole-request deadline, so they never truncate the watch's long-poll blocking
# queries.

# Bounds TCP connection establishment to the discovery server. Default: 5s.
# Keeps Resolve from parking on a dead node instead of failing fast.
#SD_DIAL_TIMEOUT=5s

# Bounds the TLS handshake to the discovery server. Default: 5s.
#SD_TLS_HANDSHAKE_TIMEOUT=5s

# Bounds time-to-first-response-header for short request/response calls
# (Resolve/Register/Deregister/heartbeat). Default: 10s. NOT applied to the watch
# client, whose blocking queries legitimately withhold headers for up to 5m.
#SD_RESPONSE_HEADER_TIMEOUT=10s

# Bounds the DynamicResolver's initial (seed) resolve. Default: 3s. The seed is
# fail-open: if it exceeds this deadline (or the server errors) the resolver is
# still built and its watch still starts — it just serves the fallback (or an
# empty address) until the watch's first success. This is a seed-only deadline;
# it never truncates the long-lived watch.
#SD_SEED_TIMEOUT=3s

# Opt reads (Resolve and Watch) into/out of Consul stale mode (AllowStale).
# "true"/"false". Default: true (stale reads). Trade-off: stale reads stay
# available during a leader blip at the cost of a possibly slightly out-of-date
# catalog view; set "false" for strongly consistent leader reads. On a single
# node there is no follower, so the default mainly future-proofs an HA upgrade.
#SD_ALLOW_STALE=true
